generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  operator
  manager
  admin
  developer
}

enum NodeStatus {
  online
  offline
  maintenance
}

enum ApiProvider {
  openai
  openweather
  accuweather
  custom
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  name          String
  role          Role           @default(operator)
  status        String         @default("active")
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  managedById   String?
  managedBy     User?          @relation("ManagerOperators", fields: [managedById], references: [id], onDelete: SetNull)
  operators     User[]         @relation("ManagerOperators")
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  operatorProvisioning ManagerOperatorProvisioning?

  @@index([managedById])
  @@index([role])
}

/// Ops Center can activate operator-account creation for a manager (default quota: 2).
model ManagerOperatorProvisioning {
  managerId    String   @id
  manager      User     @relation(fields: [managerId], references: [id], onDelete: Cascade)
  enabled      Boolean  @default(false)
  maxOperators Int      @default(2)
  updatedAt    DateTime @updatedAt
  updatedById  String?
}

model EdgeNode {
  id                  String                   @id @default(cuid())
  deviceKey           String?                  @unique
  serialNumber        String?                  @unique
  siteId              String?
  site                Site?                    @relation(fields: [siteId], references: [id])
  name                String
  location            String
  latitude            Float?
  longitude           Float?
  status              NodeStatus               @default(offline)
  firmwareVersion     String?
  batteryLevel        Float?
  signalStrength      Float?
  installedAt         DateTime                 @default(now())
  lastRestartedAt     DateTime?
  isActive            Boolean                  @default(true)
  lastSeen            DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  readings            SensorReading[]
  forecasts           DailyForecastPrediction[]
  statusLogs          EdgeNodeStatusLog[]
  maintenanceRequests NodeMaintenanceRequest[]

  @@index([status])
  @@index([lastSeen])
  @@index([siteId])
  @@index([serialNumber])
}

model EdgeNodeStatusLog {
  id         String      @id @default(cuid())
  nodeId     String
  node       EdgeNode    @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  fromStatus NodeStatus?
  toStatus   NodeStatus
  action     String
  message    String?
  metadata   Json?
  userId     String?
  createdAt  DateTime    @default(now())

  @@index([nodeId, createdAt])
  @@index([toStatus])
}

model NodeMaintenanceRequest {
  id            String    @id @default(cuid())
  nodeId        String
  node          EdgeNode  @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  requestedById String?
  issueType     String
  description   String
  status        String    @default("open")
  createdAt     DateTime  @default(now())
  resolvedAt    DateTime?

  @@index([nodeId, createdAt])
  @@index([status])
}

model SensorReading {
  id            String   @id @default(cuid())
  nodeId        String
  node          EdgeNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  voltage       Float
  current       Float
  power         Float
  energyToday   Float?
  inverterPower Float?
  curtailment   Float?
  timestamp     DateTime @default(now())

  @@index([nodeId, timestamp(sort: Desc)])
  @@index([timestamp(sort: Desc)])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model DailyForecastPrediction {
  id                String   @id @default(cuid())
  nodeId            String
  node              EdgeNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  forecastDate      DateTime
  estimatedEnergyKwh Float
  peakPowerKw       Float
  sourceConfidence  String
  generatedAt       DateTime @default(now())

  @@unique([nodeId, forecastDate])
  @@index([forecastDate])
}

model Client {
  id           String          @id @default(cuid())
  name         String
  slug         String          @unique
  contactEmail String?
  status       String          @default("active")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  sites        Site[]
  credentials  ApiCredential[]
  billingAccount BillingAccount?

  @@index([status])
}

model BillingAccount {
  id           String      @id @default(cuid())
  clientId     String      @unique
  client       Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  plan         String      @default("starter") // starter, pro, enterprise
  status       String      @default("active")  // active, suspended, past_due
  billingEmail String?
  taxId        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  invoices     Invoice[]
}

model Invoice {
  id               String         @id @default(cuid())
  billingAccountId String
  billingAccount   BillingAccount @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  amountDue        Float
  currency         String         @default("USD")
  status           String         @default("draft") // draft, open, paid, void, uncollectible
  dueDate          DateTime?
  paidAt           DateTime?
  invoicePdfUrl    String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Site {
  id           String          @id @default(cuid())
  clientId     String
  client       Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name         String
  code         String          @unique
  location     String
  timezone     String          @default("UTC")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  nodes        EdgeNode[]
  credentials  ApiCredential[]

  @@index([clientId])
}

model ApiCredential {
  id        String      @id @default(cuid())
  provider  ApiProvider
  name      String
  keyLast4  String
  isActive  Boolean     @default(true)
  notes     String?
  clientId  String?
  siteId    String?
  client    Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  site      Site?       @relation(fields: [siteId], references: [id], onDelete: SetNull)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([provider])
  @@index([clientId])
  @@index([siteId])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String?
  message    String?
  metadata   Json?
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId, createdAt])
  @@index([createdAt])
}
