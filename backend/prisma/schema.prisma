generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  operator
  manager
  admin
  developer
}

enum MembershipRole {
  portfolio_admin
  plant_manager
  operator
  engineer
  analyst
  viewer
  developer
  super_admin
}

enum MembershipStatus {
  active
  invited
  suspended
}

enum OrganisationStatus {
  active
  suspended
  archived
}

enum NodeStatus {
  online
  offline
  maintenance
}

enum NodeHealthState {
  online
  stale
  degraded
  offline
  maintenance
  disabled
}

enum ApiProvider {
  openai
  openweather
  accuweather
  custom
}

enum DataSourceType {
  measured
  calculated
  forecast
  estimated
  simulated
  operator_entered
  imported
}

enum DataQuality {
  valid
  uncertain
  stale
  missing
  invalid
  substituted
  unverified
}

/// Storage / stream environment — keeps simulation out of live KPI aggregates.
enum TelemetryEnvironment {
  live
  simulation
  hil
}

enum MeasurementUnit {
  V
  A
  Hz
  kW
  MW
  kWh
  MWh
  kVAr
  MVAr
  kVA
  MVA
  percent
  celsius
  wm2
  kg
  kg_per_hour
  litre
  litre_per_hour
  zar
  zar_per_kwh
  zar_per_mwh
  zar_per_kg
}

enum AssetType {
  grid_connection
  revenue_meter
  plant_power_controller
  inverter
  solar_array
  weather_station
  transformer
  feeder
  switchgear
  protection_relay
  bess
  battery_management_system
  battery_rack
  power_conversion_system
  electrolyser
  hydrogen_storage
  compressor
  flexible_load
  edge_gateway
  sensor
  virtual_asset
}

enum AssetStatus {
  planned
  commissioning
  operational
  maintenance
  decommissioned
  simulated
}

enum DeviceCredentialStatus {
  pending
  active
  rotating
  revoked
  expired
}

enum PlantStatus {
  planned
  operational
  maintenance
  decommissioned
  simulated
}

enum CurtailmentCause {
  grid_instruction
  network_congestion
  export_limit
  ppc_limit
  negative_price
  economic_dispatch
  inverter_clipping
  inverter_derating
  equipment_fault
  maintenance
  weather
  unknown
}

enum CurtailmentEventStatus {
  open
  closed
  under_review
  confirmed
  dismissed
}

enum GridConstraintType {
  feeder
  transformer
  line
  export
  outage
  operator
  contingency
}

/// Advisory optimisation run lifecycle. Never implies physical dispatch.
enum OptimizationRunStatus {
  pending
  running
  completed
  infeasible
  failed
}

enum SimulationRunStatus {
  running
  stopped
  failed
}

enum DispatchScheduleStatus {
  advisory
  expired
  superseded
  rejected
}

/// Plant command lifecycle. Physical actuation stays disabled until HIL + plant approval.
enum CommandRequestStatus {
  proposed
  pending_approval
  approved
  rejected
  expired
  queued
  sent
  acknowledged
  verified
  failed
  rolled_back
  cancelled
}

enum CommandSource {
  operator
  zolt_ai
  optimisation
  system
}

enum CommandRiskLevel {
  low
  medium
  high
  critical
}

enum CommandApprovalDecision {
  approved
  rejected
}

enum CommandExecutionStatus {
  queued
  sent
  acknowledged
  verified
  failed
  rolled_back
  cancelled
}

enum CommandOverrideState {
  none
  manual_override
  emergency_stop
  safe_state
}

enum AlarmSeverity {
  info
  warning
  major
  critical
}

enum AlarmStatus {
  active
  acknowledged
  cleared
  suppressed
}

enum AlarmComparator {
  gt
  gte
  lt
  lte
  eq
  neq
}

enum IncidentStatus {
  open
  investigating
  mitigated
  resolved
  closed
}

model User {
  id                       String                        @id @default(cuid())
  email                    String                        @unique
  password                 String
  name                     String
  role                     Role                          @default(operator)
  status                   String                        @default("active")
  lastLoginAt              DateTime?
  createdAt                DateTime                      @default(now())
  siteId                   String?
  site                     Site?                         @relation(fields: [siteId], references: [id], onDelete: SetNull)
  managedById              String?
  managedBy                User?                         @relation("ManagerOperators", fields: [managedById], references: [id], onDelete: SetNull)
  operators                User[]                        @relation("ManagerOperators")
  refreshTokens            RefreshToken[]
  auditLogs                AuditLog[]
  operatorProvisioning     ManagerOperatorProvisioning?
  organisationMemberships  OrganisationMembership[]
  siteMemberships          SiteMembership[]
  curtailmentCorrections   CurtailmentCorrection[]
  optimizationRuns         OptimizationRun[]
  commandRequests          CommandRequest[]          @relation("CommandRequester")
  commandApprovals         CommandApproval[]
  simulationRuns           SimulationRun[]            @relation("SimulationRunCreator")
  alarmAcknowledgements    AlarmAcknowledgement[]
  incidentsOpened          Incident[]              @relation("IncidentOpenedBy")
  incidentTimelineEntries  IncidentTimeline[]

  @@index([managedById])
  @@index([role])
  @@index([siteId])
}

model ManagerOperatorProvisioning {
  managerId    String   @id
  manager      User     @relation(fields: [managerId], references: [id], onDelete: Cascade)
  enabled      Boolean  @default(false)
  maxOperators Int      @default(2)
  updatedAt    DateTime @updatedAt
  updatedById  String?
}

/// Multi-tenant organisation. Existing Client rows remain and may link here.
model Organisation {
  id           String                    @id @default(cuid())
  name         String
  slug         String                    @unique
  status       OrganisationStatus        @default(active)
  timezone     String                    @default("Africa/Johannesburg")
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  clients      Client[]
  sites        Site[]
  plants       Plant[]
  memberships         OrganisationMembership[]
  telemetry           TelemetryReading[]
  auditLogs           AuditLog[]
  curtailmentEvents   CurtailmentEvent[]
  forecastRuns        ForecastRun[]
  gridConstraints     GridConstraint[]
  optimizationRuns    OptimizationRun[]
  commandRequests     CommandRequest[]
  simulationRuns      SimulationRun[]
  alarmRules          AlarmRule[]
  alarmEvents         AlarmEvent[]
  incidents           Incident[]

  @@index([status])
}

model OrganisationMembership {
  id             String           @id @default(cuid())
  organisationId String
  organisation   Organisation     @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           MembershipRole
  status         MembershipStatus @default(active)
  createdAt      DateTime         @default(now())

  @@unique([organisationId, userId])
  @@index([userId])
  @@index([organisationId, role])
}

model SiteMembership {
  id        String           @id @default(cuid())
  siteId    String
  site      Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      MembershipRole
  status    MembershipStatus @default(active)
  createdAt DateTime         @default(now())

  @@unique([siteId, userId])
  @@index([userId])
  @@index([siteId, role])
}

model EdgeNode {
  id                      String                   @id @default(cuid())
  deviceKey               String?                  @unique
  serialNumber            String?                  @unique
  siteId                  String?
  site                    Site?                    @relation(fields: [siteId], references: [id])
  assetId                 String?                  @unique
  asset                   Asset?                   @relation(fields: [assetId], references: [id], onDelete: SetNull)
  name                    String
  location                String
  latitude                Float?
  longitude               Float?
  status                  NodeStatus               @default(offline)
  healthState             NodeHealthState          @default(offline)
  firmwareVersion         String?
  batteryLevel            Float?
  signalStrength          Float?
  enclosureTemperatureC   Float?
  storageUtilisationPct   Float?
  queueDepth              Int?
  restartCount            Int                      @default(0)
  watchdogResetCount      Int                      @default(0)
  heartbeatIntervalSec    Int                      @default(60)
  staleAfterSec           Int                      @default(120)
  offlineAfterSec         Int                      @default(600)
  lastSuccessfulIngestAt  DateTime?
  lastInvalidPayloadAt    DateTime?
  lastAuthFailureAt       DateTime?
  installedAt             DateTime                 @default(now())
  lastRestartedAt         DateTime?
  isActive                Boolean                  @default(true)
  lastSeen                DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  readings                SensorReading[]
  forecasts               DailyForecastPrediction[]
  statusLogs              EdgeNodeStatusLog[]
  maintenanceRequests     NodeMaintenanceRequest[]
  credentials             DeviceCredential[]
  provisioningEvents      DeviceProvisioningEvent[]
  healthHistory           NodeHealthHistory[]
  simulationRuns          SimulationRun[]
  lastResetReason         String?
  appliedConfigVersion    String?

  @@index([status])
  @@index([healthState])
  @@index([lastSeen])
  @@index([siteId])
  @@index([serialNumber])
}

model EdgeNodeStatusLog {
  id         String      @id @default(cuid())
  nodeId     String
  node       EdgeNode    @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  fromStatus NodeStatus?
  toStatus   NodeStatus
  action     String
  message    String?
  metadata   Json?
  userId     String?
  createdAt  DateTime    @default(now())

  @@index([nodeId, createdAt])
  @@index([toStatus])
}

model NodeHealthHistory {
  id          String          @id @default(cuid())
  nodeId      String
  node        EdgeNode        @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  fromState   NodeHealthState?
  toState     NodeHealthState
  reason      String?
  metadata    Json?
  createdAt   DateTime        @default(now())

  @@index([nodeId, createdAt])
}

model NodeMaintenanceRequest {
  id            String    @id @default(cuid())
  nodeId        String
  node          EdgeNode  @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  requestedById String?
  issueType     String
  description   String
  status        String    @default("open")
  createdAt     DateTime  @default(now())
  resolvedAt    DateTime?

  @@index([nodeId, createdAt])
  @@index([status])
}

model SensorReading {
  id                 String          @id @default(cuid())
  nodeId             String
  node               EdgeNode        @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  voltage            Float
  current            Float
  power              Float
  energyToday        Float?
  inverterPower      Float?
  curtailment        Float?
  /// Device-reported timestamp (preserve original clock).
  deviceTimestamp    DateTime?
  /// Server ingestion timestamp.
  ingestedAt         DateTime        @default(now())
  /// Legacy field kept for compatibility; prefer deviceTimestamp/ingestedAt.
  timestamp          DateTime        @default(now())
  sequenceNumber     BigInt?
  schemaVersion      String?         @default("1")
  firmwareVersion    String?
  calibrationVersion String?
  qualityFlags       Json?
  sourceAssetId      String?
  sourceType         DataSourceType  @default(measured)
  quality            DataQuality     @default(valid)
  environment        TelemetryEnvironment @default(live)
  simulationRunId    String?
  simulationRun      SimulationRun?  @relation(fields: [simulationRunId], references: [id], onDelete: SetNull)
  powerUnit          MeasurementUnit @default(kW)
  voltageUnit        MeasurementUnit @default(V)
  currentUnit        MeasurementUnit @default(A)

  @@unique([nodeId, sequenceNumber])
  @@index([nodeId, timestamp(sort: Desc)])
  @@index([timestamp(sort: Desc)])
  @@index([nodeId, ingestedAt(sort: Desc)])
  @@index([sourceType])
  @@index([quality])
  @@index([environment])
  @@index([simulationRunId])
}

/// Idempotent acknowledgement ledger for store-and-forward retries.
/// Uniqueness is on device identity (deviceKey) + sequenceNumber — not asset/time.
model EdgeIngestReceipt {
  id             String   @id @default(cuid())
  deviceId       String
  sequenceNumber BigInt
  messageId      String?
  readingId      String?
  payloadHash    String?
  acknowledgedAt DateTime @default(now())

  @@unique([deviceId, sequenceNumber])
  @@index([deviceId, acknowledgedAt])
}

/// Signed edge remote configuration (Ed25519). Never carries device HMAC secrets.
model EdgeRemoteConfig {
  id                     String   @id @default(cuid())
  configVersion          String   @unique
  pollingIntervalMs      Int
  serverEndpoint         String
  enabledTelemetryKeys   Json
  approvedFirmwareMinimum String
  issuedAt               DateTime
  expiresAt              DateTime
  /// Canonical JSON bytes that were signed (UTF-8).
  payloadJson            String
  /// Base64url Ed25519 signature over payloadJson.
  signature              String
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  createdById            String?

  @@index([isActive, issuedAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model DailyForecastPrediction {
  id                 String   @id @default(cuid())
  nodeId             String
  node               EdgeNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  forecastDate       DateTime
  estimatedEnergyKwh Float
  peakPowerKw        Float
  sourceConfidence   String
  generatedAt        DateTime @default(now())

  @@unique([nodeId, forecastDate])
  @@index([forecastDate])
}

/// Legacy commercial client record. Prefer Organisation for new tenancy work.
model Client {
  id             String          @id @default(cuid())
  name           String
  slug           String          @unique
  contactEmail   String?
  status         String          @default("active")
  organisationId String?
  organisation   Organisation?   @relation(fields: [organisationId], references: [id], onDelete: SetNull)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  sites          Site[]
  credentials    ApiCredential[]
  billingAccount BillingAccount?

  @@index([status])
  @@index([organisationId])
}

model BillingAccount {
  id           String      @id @default(cuid())
  clientId     String      @unique
  client       Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  plan         String      @default("starter")
  status       String      @default("active")
  billingEmail String?
  taxId        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  invoices     Invoice[]
}

model Invoice {
  id               String         @id @default(cuid())
  billingAccountId String
  billingAccount   BillingAccount @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  amountDue        Float
  currency         String         @default("USD")
  status           String         @default("draft")
  dueDate          DateTime?
  paidAt           DateTime?
  invoicePdfUrl    String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Site {
  id             String            @id @default(cuid())
  clientId       String
  client         Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  organisationId String?
  organisation   Organisation?     @relation(fields: [organisationId], references: [id], onDelete: SetNull)
  name           String
  code           String            @unique
  location       String
  timezone       String            @default("UTC")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  nodes          EdgeNode[]
  users          User[]
  credentials    ApiCredential[]
  plants              Plant[]
  memberships         SiteMembership[]
  telemetry           TelemetryReading[]
  curtailmentEvents   CurtailmentEvent[]
  forecastRuns        ForecastRun[]
  gridConstraints     GridConstraint[]
  optimizationRuns    OptimizationRun[]
  commandRequests     CommandRequest[]
  simulationRuns      SimulationRun[]
  alarmRules          AlarmRule[]
  alarmEvents         AlarmEvent[]
  incidents           Incident[]

  @@index([clientId])
  @@index([organisationId])
}

model Plant {
  id                  String             @id @default(cuid())
  organisationId      String
  organisation        Organisation       @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  siteId              String
  site                Site               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name                String
  code                String
  technology          String             @default("solar_pv")
  installedCapacityKw Float              @default(0)
  exportCapacityKw    Float              @default(0)
  timezone            String             @default("Africa/Johannesburg")
  latitude            Float?
  longitude           Float?
  status              PlantStatus        @default(simulated)
  dataSourceType      DataSourceType     @default(simulated)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  assets              Asset[]
  telemetry           TelemetryReading[]
  forecastConfig      PlantForecastConfig?
  curtailmentEvents   CurtailmentEvent[]
  forecastRuns        ForecastRun[]
  accuracyScores      ForecastAccuracyScore[]
  gridConstraints     GridConstraint[]
  optimizationRuns    OptimizationRun[]
  commandRequests     CommandRequest[]
  alarmRules          AlarmRule[]
  alarmEvents         AlarmEvent[]
  incidents           Incident[]

  @@unique([organisationId, code])
  @@index([siteId])
  @@index([organisationId, status])
}

model Asset {
  id                String            @id @default(cuid())
  plantId           String
  plant             Plant             @relation(fields: [plantId], references: [id], onDelete: Cascade)
  parentAssetId     String?
  parentAsset       Asset?            @relation("AssetHierarchy", fields: [parentAssetId], references: [id], onDelete: SetNull)
  childAssets       Asset[]           @relation("AssetHierarchy")
  type              AssetType
  name              String
  manufacturer      String?
  model             String?
  serialNumber      String?
  protocol          String?
  externalReference String?
  ratedPowerKw      Float?
  ratedEnergyKwh    Float?
  status            AssetStatus       @default(simulated)
  dataSourceType    DataSourceType    @default(simulated)
  commissionedAt    DateTime?
  metadata          Json?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  edgeNode          EdgeNode?
  constraints       AssetConstraint[]
  state             AssetState?
  pointDefinitions             TelemetryPointDefinition[]
  telemetry                    TelemetryReading[]
  bessModelConfig              BessModelConfig?
  bessState                    BessOperatingState?
  electrolyserModelConfig      ElectrolyserModelConfig?
  electrolyserState            ElectrolyserOperatingState?
  dispatchSchedules            DispatchSchedule[]
  commandRequests              CommandRequest[]
  alarmRules                   AlarmRule[]
  alarmEvents                  AlarmEvent[]

  @@index([plantId, type])
  @@index([parentAssetId])
  @@index([serialNumber])
}

model AssetConstraint {
  id            String          @id @default(cuid())
  assetId       String
  asset         Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  constraintType String
  minimumValue  Float?
  maximumValue  Float?
  unit          MeasurementUnit
  validFrom     DateTime?
  validTo       DateTime?
  source        DataSourceType  @default(operator_entered)
  approvedBy    String?
  metadata      Json?
  createdAt     DateTime        @default(now())

  @@index([assetId, constraintType])
}

model AssetState {
  assetId             String    @id
  asset               Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  operatingState      String    @default("unknown")
  available           Boolean   @default(true)
  lastCommunicationAt DateTime?
  alarmState          String?
  metadata            Json?
  updatedAt           DateTime  @updatedAt
}

model TelemetryPointDefinition {
  id                String          @id @default(cuid())
  assetId           String
  asset             Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  key               String
  displayName       String
  unit              MeasurementUnit
  dataType          String          @default("number")
  sourceType        DataSourceType  @default(measured)
  minimumValidValue Float?
  maximumValidValue Float?
  writable          Boolean         @default(false)
  critical          Boolean         @default(false)
  metadata          Json?
  createdAt         DateTime        @default(now())
  readings          TelemetryReading[]

  @@unique([assetId, key])
  @@index([key])
}

model TelemetryReading {
  id                 String                   @id @default(cuid())
  organisationId     String
  organisation       Organisation             @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  siteId             String
  site               Site                     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  plantId            String
  plant              Plant                    @relation(fields: [plantId], references: [id], onDelete: Cascade)
  assetId            String
  asset              Asset                    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  pointDefinitionId  String?
  pointDefinition    TelemetryPointDefinition? @relation(fields: [pointDefinitionId], references: [id], onDelete: SetNull)
  key                String
  numericValue       Float?
  stringValue        String?
  booleanValue       Boolean?
  unit               MeasurementUnit
  quality            DataQuality              @default(valid)
  sourceType         DataSourceType           @default(measured)
  environment        TelemetryEnvironment     @default(live)
  simulationRunId    String?
  simulationRun      SimulationRun?           @relation(fields: [simulationRunId], references: [id], onDelete: SetNull)
  deviceTimestamp    DateTime
  ingestedAt         DateTime                 @default(now())
  sequenceNumber     BigInt?
  schemaVersion      String                   @default("2")
  firmwareVersion    String?
  calibrationVersion String?
  qualityFlags       Json?
  rawPayloadReference String?

  @@unique([assetId, key, deviceTimestamp, sequenceNumber])
  @@index([organisationId, deviceTimestamp])
  @@index([siteId, deviceTimestamp])
  @@index([plantId, deviceTimestamp])
  @@index([assetId, key, deviceTimestamp])
  @@index([ingestedAt])
  @@index([environment])
  @@index([simulationRunId])
}

model DeviceCredential {
  id                  String                 @id @default(cuid())
  edgeNodeId          String
  edgeNode            EdgeNode               @relation(fields: [edgeNodeId], references: [id], onDelete: Cascade)
  credentialId        String                 @unique
  /// Legacy transitional field (SHA-256 of secret used as HMAC key). Kept nullable until devices are re-provisioned; new credentials leave this null.
  secretHash          String?
  keyVersion          Int                    @default(1)
  /// AES-GCM / KMS ciphertext of the 256-bit device secret (base64url). Required for vaulted credentials.
  encryptedSecret     String?
  /// Optional envelope-encrypted data key (KMS providers).
  encryptedDataKey    String?
  /// SHA-256 hex fingerprint of the plaintext secret — for lookup/audit only, never for HMAC.
  secretFingerprint   String?
  /// KMS / local vault key identifier used to encrypt this secret.
  encryptionKeyId     String?
  algorithm           String                 @default("HMAC-SHA256")
  status              DeviceCredentialStatus @default(active)
  lastSequenceNumber  BigInt?
  /// SHA-256 hex of raw body accepted for lastSequenceNumber — binds idempotent retries to the same payload.
  lastAcceptedBodyHash String?
  createdAt           DateTime               @default(now())
  expiresAt           DateTime?
  lastUsedAt          DateTime?
  revokedAt           DateTime?
  rotatedAt           DateTime?

  @@index([edgeNodeId, status])
  @@index([keyVersion])
  @@index([secretFingerprint])
}

model DeviceProvisioningEvent {
  id         String   @id @default(cuid())
  edgeNodeId String
  edgeNode   EdgeNode @relation(fields: [edgeNodeId], references: [id], onDelete: Cascade)
  action     String
  actorId    String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([edgeNodeId, createdAt])
}

model ApiCredential {
  id        String      @id @default(cuid())
  provider  ApiProvider
  name      String
  keyLast4  String
  isActive  Boolean     @default(true)
  notes     String?
  clientId  String?
  siteId    String?
  client    Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  site      Site?       @relation(fields: [siteId], references: [id], onDelete: SetNull)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([provider])
  @@index([clientId])
  @@index([siteId])
}

model AuditLog {
  id             String        @id @default(cuid())
  action         String
  entityType     String
  entityId       String?
  message        String?
  metadata       Json?
  userId         String?
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organisationId String?
  organisation   Organisation? @relation(fields: [organisationId], references: [id], onDelete: SetNull)
  siteId         String?
  createdAt      DateTime      @default(now())

  @@index([entityType, entityId])
  @@index([userId, createdAt])
  @@index([organisationId, createdAt])
  @@index([siteId, createdAt])
  @@index([createdAt])
}

/// Detected curtailment interval. Powers in kW, energies in kWh.
model CurtailmentEvent {
  id                      String                 @id @default(cuid())
  organisationId          String
  organisation            Organisation           @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  siteId                  String
  site                    Site                   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  plantId                 String
  plant                   Plant                  @relation(fields: [plantId], references: [id], onDelete: Cascade)
  startTime               DateTime
  endTime                 DateTime?
  status                  CurtailmentEventStatus @default(open)
  cause                   CurtailmentCause       @default(unknown)
  causeConfidence         Float                  @default(0)
  availablePowerKw        Float
  actualPowerKw           Float
  curtailedPowerKw        Float
  estimatedLostEnergyKwh  Float                  @default(0)
  recoverableEnergyKwh    Float                  @default(0)
  exportLimitKw           Float?
  ppcSetpointKw           Float?
  evidence                Json?
  calculationVersion      String
  reviewedBy              String?
  reviewedAt              DateTime?
  operatorNotes           String?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  corrections             CurtailmentCorrection[]

  @@index([organisationId, startTime])
  @@index([siteId, startTime])
  @@index([plantId, startTime])
  @@index([status, cause])
  @@index([calculationVersion])
}

/// Operator correction notes ΓÇö never overwrites original event calculations.
model CurtailmentCorrection {
  id                             String            @id @default(cuid())
  eventId                        String
  event                          CurtailmentEvent  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  correctedCause                 CurtailmentCause?
  correctedRecoverableEnergyKwh  Float?
  notes                          String
  createdById                    String?
  createdBy                      User?             @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt                      DateTime          @default(now())

  @@index([eventId, createdAt])
  @@index([createdById])
}

model PlantForecastConfig {
  id            String   @id @default(cuid())
  plantId       String   @unique
  plant         Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)
  dcCapacityKw  Float
  acCapacityKw  Float
  tiltDeg       Float    @default(20)
  azimuthDeg    Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// Immutable forecast vintage for a plant.
model ForecastRun {
  id               String         @id @default(cuid())
  organisationId   String
  organisation     Organisation   @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  siteId           String
  site             Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  plantId          String
  plant            Plant          @relation(fields: [plantId], references: [id], onDelete: Cascade)
  provider         String
  version          String
  sourceType       DataSourceType @default(forecast)
  quality          DataQuality    @default(unverified)
  generatedAt      DateTime       @default(now())
  validFrom        DateTime
  validTo          DateTime
  freshnessSeconds Int?
  metadata         Json?
  createdAt        DateTime       @default(now())
  values           ForecastValue[]

  @@index([organisationId, generatedAt])
  @@index([siteId, generatedAt])
  @@index([plantId, generatedAt])
  @@index([provider, version])
  @@index([sourceType, quality])
}

model ForecastValue {
  id             String          @id @default(cuid())
  forecastRunId  String
  forecastRun    ForecastRun     @relation(fields: [forecastRunId], references: [id], onDelete: Cascade)
  targetTime     DateTime
  horizonMinutes Int
  p10Kw          Float?
  p50Kw          Float
  p90Kw          Float?
  unit           MeasurementUnit @default(kW)
  sourceType     DataSourceType  @default(forecast)
  quality        DataQuality     @default(unverified)

  @@index([forecastRunId, targetTime])
  @@index([targetTime, horizonMinutes])
}

model ForecastAccuracyScore {
  id                 String   @id @default(cuid())
  plantId            String
  plant              Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)
  horizonMinutes     Int
  provider           String?
  maeKw              Float
  rmseKw             Float
  mapePercent        Float?
  biasKw             Float
  sampleCount        Int
  periodStart        DateTime
  periodEnd          DateTime
  scoredAt           DateTime @default(now())
  calculationVersion String   @default("forecast-score-v1")
  metadata           Json?

  @@index([plantId, horizonMinutes, scoredAt])
  @@index([provider, scoredAt])
}

/// Explicit grid constraint inputs ΓÇö not inferred from high PV output.
model GridConstraint {
  id             String             @id @default(cuid())
  organisationId String
  organisation   Organisation       @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  siteId         String
  site           Site               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  plantId        String?
  plant          Plant?             @relation(fields: [plantId], references: [id], onDelete: SetNull)
  constraintType GridConstraintType
  name           String
  limitValue     Float
  unit           MeasurementUnit
  validFrom      DateTime?
  validTo        DateTime?
  sourceType     DataSourceType     @default(operator_entered)
  quality        DataQuality        @default(unverified)
  provenance     Json?
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([organisationId, constraintType])
  @@index([siteId, constraintType])
  @@index([plantId, constraintType])
  @@index([validFrom, validTo])
  @@index([sourceType])
}

/// Configured BESS parameters. Distinguish configSource from measured state.
model BessModelConfig {
  id                        String         @id @default(cuid())
  assetId                   String         @unique
  asset                     Asset          @relation(fields: [assetId], references: [id], onDelete: Cascade)
  ratedPowerKw              Float
  ratedEnergyKwh            Float
  minSocPercent             Float          @default(10)
  maxSocPercent             Float          @default(90)
  chargeEfficiency          Float          @default(0.95)
  dischargeEfficiency       Float          @default(0.95)
  maxChargePowerKw          Float
  maxDischargePowerKw       Float
  rampLimitKwPerMin         Float          @default(500)
  degradationCostZarPerMwh  Float          @default(120)
  reserveSocPercent         Float          @default(15)
  minOperatingTempC         Float?
  maxOperatingTempC         Float?
  warrantyCycleLimit        Int?
  simulationMode            Boolean        @default(true)
  configSource              DataSourceType @default(operator_entered)
  metadata                  Json?
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt
}

model BessOperatingState {
  assetId                     String         @id
  asset                       Asset          @relation(fields: [assetId], references: [id], onDelete: Cascade)
  socPercent                  Float
  socSource                   DataSourceType @default(simulated)
  socQuality                  DataQuality    @default(unverified)
  temperatureC                Float?
  chargePowerKw               Float          @default(0)
  dischargePowerKw            Float          @default(0)
  availableChargePowerKw      Float?
  availableDischargePowerKw   Float?
  cycleCount                  Int?
  alarmState                  String?
  operatingState              String         @default("unknown")
  simulationMode              Boolean        @default(true)
  asOf                        DateTime?
  updatedAt                   DateTime       @updatedAt
}

/// Configured electrolyser parameters with provenance on configSource.
model ElectrolyserModelConfig {
  id                         String         @id @default(cuid())
  assetId                    String         @unique
  asset                      Asset          @relation(fields: [assetId], references: [id], onDelete: Cascade)
  technology                 String         @default("alkaline")
  minStableLoadKw            Float
  maxLoadKw                  Float
  rampRateKwPerMin           Float          @default(250)
  startUpTimeMin             Float          @default(15)
  shutDownTimeMin            Float          @default(10)
  minRunTimeMin              Float          @default(30)
  efficiencyKwhPerKg         Float          @default(52)
  waterLitresPerKg           Float          @default(10)
  hydrogenStorageCapacityKg  Float
  hydrogenSalePriceZarPerKg  Float          @default(85)
  operatingCostZarPerHour    Float          @default(400)
  minOperatingTempC          Float?
  maxOperatingTempC          Float?
  maintenanceWindowActive    Boolean        @default(false)
  simulationMode             Boolean        @default(true)
  configSource               DataSourceType @default(operator_entered)
  metadata                   Json?
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt
}

model ElectrolyserOperatingState {
  assetId               String         @id
  asset                 Asset          @relation(fields: [assetId], references: [id], onDelete: Cascade)
  loadPowerKw           Float          @default(0)
  loadSource            DataSourceType @default(simulated)
  loadQuality           DataQuality    @default(unverified)
  productionKgPerHour   Float          @default(0)
  storageLevelKg        Float          @default(0)
  waterFlowLitrePerHour Float?
  stackTemperatureC     Float?
  operatingMode         String         @default("standby")
  alarmState            String?
  runTimeMinutes        Float          @default(0)
  simulationMode        Boolean        @default(true)
  asOf                  DateTime?
  updatedAt             DateTime       @updatedAt
}

model OptimizationRun {
  id                    String                @id @default(cuid())
  organisationId        String
  organisation          Organisation          @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  siteId                String
  site                  Site                  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  plantId               String
  plant                 Plant                 @relation(fields: [plantId], references: [id], onDelete: Cascade)
  objective             String
  status                OptimizationRunStatus @default(pending)
  solverVersion         String
  forecastVersion       String?
  inputs                Json
  assumptions           Json?
  result                Json?
  constraintViolations  Json?
  warnings              Json?
  baselineComparison    Json?
  expectedBenefitZar    Float?
  advisory              Boolean               @default(true)
  startedAt             DateTime?
  completedAt           DateTime?
  createdById           String?
  createdBy             User?                 @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  schedules             DispatchSchedule[]

  @@index([organisationId, createdAt])
  @@index([siteId, createdAt])
  @@index([plantId, createdAt])
  @@index([status])
  @@index([createdById])
}

/// Tenant-owned live simulation stream targeting one persisted site node.
model SimulationRun {
  id             String              @id @default(cuid())
  organisationId String
  organisation   Organisation        @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  siteId         String
  site           Site                @relation(fields: [siteId], references: [id], onDelete: Cascade)
  targetNodeId   String
  targetNode     EdgeNode            @relation(fields: [targetNodeId], references: [id], onDelete: Cascade)
  status         SimulationRunStatus @default(running)
  createdById    String?
  createdBy      User?               @relation("SimulationRunCreator", fields: [createdById], references: [id], onDelete: SetNull)
  startedAt      DateTime            @default(now())
  stoppedAt      DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  sensorReadings SensorReading[]
  telemetry      TelemetryReading[]

  @@index([organisationId, createdAt])
  @@index([siteId, createdAt])
  @@index([targetNodeId, status])
  @@index([status, startedAt])
  @@index([createdById])
}

model DispatchSchedule {
  id                String                 @id @default(cuid())
  optimizationRunId String
  optimizationRun   OptimizationRun        @relation(fields: [optimizationRunId], references: [id], onDelete: Cascade)
  assetId           String
  asset             Asset                  @relation(fields: [assetId], references: [id], onDelete: Cascade)
  intervalStart     DateTime
  intervalEnd       DateTime
  targetValue       Float
  unit              MeasurementUnit        @default(kW)
  expectedValue     Float?
  status            DispatchScheduleStatus @default(advisory)
  metadata          Json?
  createdAt         DateTime               @default(now())

  @@index([optimizationRunId, intervalStart])
  @@index([assetId, intervalStart])
  @@index([status])
}

/// Advisory / approval-gated plant command. Physical send requires feature flag + HIL.
model CommandRequest {
  id                String               @id @default(cuid())
  organisationId    String
  organisation      Organisation         @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  siteId            String
  site              Site                 @relation(fields: [siteId], references: [id], onDelete: Cascade)
  plantId           String
  plant             Plant                @relation(fields: [plantId], references: [id], onDelete: Cascade)
  targetAssetId     String
  targetAsset       Asset                @relation(fields: [targetAssetId], references: [id], onDelete: Cascade)
  commandType       String
  requestedValue    Float
  unit              MeasurementUnit
  currentValue      Float?
  minimumAllowed    Float?
  maximumAllowed    Float?
  /// Maximum absolute change from currentValue per minute (same unit as requestedValue).
  maxRampPerMinute  Float?
  requestedById     String?
  requestedBy       User?                @relation("CommandRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  requestedAt       DateTime             @default(now())
  reason            String
  source            CommandSource        @default(operator)
  riskLevel         CommandRiskLevel     @default(medium)
  /// When true, requester cannot approve (separation of duties).
  requireSeparationOfDuties Boolean      @default(true)
  optimisationRunId String?
  expiresAt         DateTime
  status            CommandRequestStatus @default(proposed)
  overrideState     CommandOverrideState @default(none)
  advisoryOnly      Boolean              @default(true)
  metadata          Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  approvals         CommandApproval[]
  executions        CommandExecution[]

  @@index([organisationId, status])
  @@index([siteId, status])
  @@index([plantId, status])
  @@index([targetAssetId, requestedAt])
  @@index([status, expiresAt])
  @@index([requestedById])
}

model CommandApproval {
  id               String                   @id @default(cuid())
  commandRequestId String
  commandRequest   CommandRequest           @relation(fields: [commandRequestId], references: [id], onDelete: Cascade)
  approverId       String?
  approver         User?                    @relation(fields: [approverId], references: [id], onDelete: SetNull)
  decision         CommandApprovalDecision
  reason           String?
  timestamp        DateTime                 @default(now())

  @@index([commandRequestId, timestamp])
  @@index([approverId])
}

model CommandExecution {
  id                 String                  @id @default(cuid())
  commandRequestId   String
  commandRequest     CommandRequest          @relation(fields: [commandRequestId], references: [id], onDelete: Cascade)
  /// Always "simulated" until PHYSICAL_COMMAND_EXECUTION_ENABLED and HIL validation.
  executorMode       String                  @default("simulated")
  sentAt             DateTime?
  acknowledgedAt     DateTime?
  readBackAt         DateTime?
  expectedValue      Float?
  readBackValue      Float?
  status             CommandExecutionStatus  @default(queued)
  failureReason      String?
  rollbackStatus     String?
  rawProtocolResponse Json?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@index([commandRequestId, createdAt])
  @@index([status])
}

/// Tenant-scoped alarm threshold rule. GridFlex alarms are advisory — they do not replace protection relays, PPC, or BMS.
model AlarmRule {
  id              String          @id @default(cuid())
  organisationId  String
  organisation    Organisation    @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  siteId          String?
  site            Site?           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  plantId         String?
  plant           Plant?          @relation(fields: [plantId], references: [id], onDelete: SetNull)
  assetId         String?
  asset           Asset?          @relation(fields: [assetId], references: [id], onDelete: SetNull)
  name            String
  description     String?
  metricKey       String
  comparator      AlarmComparator @default(gt)
  threshold       Float
  severity        AlarmSeverity   @default(warning)
  enabled         Boolean         @default(true)
  cooldownSeconds Int             @default(300)
  metadata        Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  events          AlarmEvent[]

  @@index([organisationId, enabled])
  @@index([siteId, metricKey])
  @@index([plantId])
  @@index([assetId])
}

model AlarmEvent {
  id               String                 @id @default(cuid())
  organisationId   String
  organisation     Organisation           @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  siteId           String
  site             Site                   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  plantId          String?
  plant            Plant?                 @relation(fields: [plantId], references: [id], onDelete: SetNull)
  assetId          String?
  asset            Asset?                 @relation(fields: [assetId], references: [id], onDelete: SetNull)
  ruleId           String?
  rule             AlarmRule?             @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  incidentId       String?
  incident         Incident?              @relation(fields: [incidentId], references: [id], onDelete: SetNull)
  severity         AlarmSeverity          @default(warning)
  status           AlarmStatus            @default(active)
  title            String
  message          String
  metricKey        String?
  metricValue      Float?
  threshold        Float?
  startedAt        DateTime               @default(now())
  clearedAt        DateTime?
  metadata         Json?
  acknowledgements AlarmAcknowledgement[]

  @@index([organisationId, status, startedAt])
  @@index([siteId, status, startedAt])
  @@index([ruleId, startedAt])
  @@index([incidentId])
}

model AlarmAcknowledgement {
  id             String     @id @default(cuid())
  alarmEventId   String
  alarmEvent     AlarmEvent @relation(fields: [alarmEventId], references: [id], onDelete: Cascade)
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  note           String?
  acknowledgedAt DateTime   @default(now())

  @@index([alarmEventId, acknowledgedAt])
  @@index([userId, acknowledgedAt])
}

model Incident {
  id             String             @id @default(cuid())
  organisationId String
  organisation   Organisation       @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  siteId         String
  site           Site               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  plantId        String?
  plant          Plant?             @relation(fields: [plantId], references: [id], onDelete: SetNull)
  status         IncidentStatus     @default(open)
  severity       AlarmSeverity      @default(major)
  title          String
  summary        String?
  openedAt       DateTime           @default(now())
  closedAt       DateTime?
  openedById     String?
  openedBy       User?              @relation("IncidentOpenedBy", fields: [openedById], references: [id], onDelete: SetNull)
  timeline       IncidentTimeline[]
  alarmEvents    AlarmEvent[]

  @@index([organisationId, status, openedAt])
  @@index([siteId, status, openedAt])
  @@index([openedById])
}

model IncidentTimeline {
  id          String   @id @default(cuid())
  incidentId  String
  incident    Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  actorUserId String?
  actorUser   User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  eventType   String
  message     String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([incidentId, createdAt])
  @@index([actorUserId])
}
