# Local development placeholders ONLY — never put production secrets here.
# Production values live in the hosting secret manager (+ AWS KMS for device vault).
# See docs/MANAGED_SECRETS.md and docs/SECRETS_INVENTORY.md.

NODE_ENV=development
PORT=4000
HTTPS_ENABLED=false
HTTPS_PORT=4443
HTTPS_PFX_PATH=
HTTPS_PFX_PASSPHRASE=
HTTPS_CERT_PATH=
HTTPS_KEY_PATH=
FORCE_HTTPS=false
TRUST_PROXY=true
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gridflex?schema=public

# JWT — use overlapping kids for rotation (docs/MANAGED_SECRETS.md)
JWT_SECRET=dev-only-jwt-secret-change-me
JWT_ACTIVE_KID=legacy
# JWT_SECRETS_JSON={"legacy":"dev-only-jwt-secret-change-me","v2":"dev-only-next-secret"}
# JWT_PREVIOUS_SECRET=
# JWT_PREVIOUS_KID=previous
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

CORS_ORIGIN=http://localhost:5173
ADMIN_ALLOWED_EMAILS=admin@gridflex.ai
ADMIN_ALLOWED_IPS=
ADMIN_REQUIRE_HTTPS=true
ADMIN_MAX_TOKEN_AGE_MINUTES=30

# Legacy edge shared secret — disable for pilot/production
EDGE_INGEST_SHARED_SECRET=dev-only-edge-secret-change-me
EDGE_ALLOW_LEGACY_SHARED_SECRET=false
EDGE_REPLAY_REQUIRE_REDIS=false
EDGE_ALLOW_MEMORY_REPLAY=true
EDGE_INGEST_MAX_SKEW_SECONDS=300
EDGE_RATE_LIMIT_MAX_PER_MINUTE=30

# Ed25519 remote-config signing (PEMs from secret manager in prod)
# EDGE_CONFIG_SIGNING_PRIVATE_KEY_PEM=
# EDGE_CONFIG_SIGNING_PUBLIC_KEY_PEM=

FORECAST_RATE_LIMIT_MAX_PER_MINUTE=20
FORECAST_CRON_ENABLED=true
FORECAST_CRON_SCHEDULE=*/30 * * * *
PHYSICAL_COMMAND_EXECUTION_ENABLED=false
HIL_PLANT_APPROVAL_CONFIRMED=false
# Keep true for pilot — clear only after written HIL/plant approval.
PILOT_LOCK_PHYSICAL_EXECUTION=true

# Device secret vault: `local` ONLY for development/test. Production: aws_kms.
DEVICE_SECRET_VAULT_PROVIDER=local
DEVICE_SECRET_VAULT_KEY=dGVzdC1kZXZpY2Utc2VjcmV0LXZhdWx0LWtleS0zMiEh
DEVICE_SECRET_VAULT_KEY_ID=local-dev
# AWS_KMS_KEY_ID=arn:aws:kms:region:account:key/id

GRIDFLEX_OPERATING_MODE=SIMULATION
SIMULATION_TELEMETRY_INTERVAL_MS=5000
TELEMETRY_RETENTION_DAYS=365
TELEMETRY_RETENTION_CRON_ENABLED=false
TELEMETRY_RETENTION_CRON_SCHEDULE=15 3 * * *
TELEMETRY_RETENTION_PURGE_ENABLED=false
REDIS_URL=redis://localhost:6379

# Observability
# METRICS_SCRAPE_TOKEN=dev-metrics-token-16c
# OTEL_SERVICE_NAME=gridflex-api

# Third-party keys — placeholders only
OPENWEATHER_API_KEY=replace-me-openweather
ACCUWEATHER_API_KEY=replace-me-accuweather
OPENAI_API_KEY=replace-me-openai
FORECAST_CIRCUIT_FAILURE_THRESHOLD=3
FORECAST_CIRCUIT_OPEN_MS=180000
