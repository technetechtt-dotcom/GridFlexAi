NODE_ENV=development
PORT=4000
HTTPS_ENABLED=false
HTTPS_PORT=4443
HTTPS_PFX_PATH=
HTTPS_PFX_PASSPHRASE=
HTTPS_CERT_PATH=C:\path\to\cert.pem
HTTPS_KEY_PATH=C:\path\to\key.pem
FORCE_HTTPS=false
TRUST_PROXY=true
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gridflex?schema=public
JWT_SECRET=change-this-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
CORS_ORIGIN=http://localhost:5173
ADMIN_ALLOWED_EMAILS=admin@gridflex.ai
ADMIN_ALLOWED_IPS=
ADMIN_REQUIRE_HTTPS=true
ADMIN_MAX_TOKEN_AGE_MINUTES=30
EDGE_INGEST_SHARED_SECRET=change-this-edge-secret
EDGE_INGEST_MAX_SKEW_SECONDS=300
EDGE_RATE_LIMIT_MAX_PER_MINUTE=30
FORECAST_RATE_LIMIT_MAX_PER_MINUTE=20
FORECAST_CRON_ENABLED=true
FORECAST_CRON_SCHEDULE=*/30 * * * *
REDIS_URL=redis://localhost:6379
OPENWEATHER_API_KEY=your_openweather_key
ACCUWEATHER_API_KEY=your_accuweather_key
OPENAI_API_KEY=your_openai_key
FORECAST_CIRCUIT_FAILURE_THRESHOLD=3
FORECAST_CIRCUIT_OPEN_MS=180000
