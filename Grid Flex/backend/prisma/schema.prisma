generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  operator
  manager
  admin
  developer
}

enum NodeStatus {
  online
  offline
}

enum ApiProvider {
  openai
  openweather
  accuweather
  custom
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  name          String
  role          Role           @default(operator)
  status        String         @default("active")
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
}

model EdgeNode {
  id        String          @id @default(cuid())
  deviceKey String?         @unique
  siteId    String?
  site      Site?           @relation(fields: [siteId], references: [id])
  name      String
  location  String
  latitude  Float?
  longitude Float?
  status    NodeStatus      @default(offline)
  lastSeen  DateTime?
  createdAt DateTime        @default(now())
  readings  SensorReading[]
  forecasts DailyForecastPrediction[]

  @@index([status])
  @@index([lastSeen])
  @@index([siteId])
}

model SensorReading {
  id            String   @id @default(cuid())
  nodeId        String
  node          EdgeNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  voltage       Float
  current       Float
  power         Float
  energyToday   Float?
  inverterPower Float?
  curtailment   Float?
  timestamp     DateTime @default(now())

  @@index([nodeId, timestamp(sort: Desc)])
  @@index([timestamp(sort: Desc)])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model DailyForecastPrediction {
  id                String   @id @default(cuid())
  nodeId            String
  node              EdgeNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  forecastDate      DateTime
  estimatedEnergyKwh Float
  peakPowerKw       Float
  sourceConfidence  String
  generatedAt       DateTime @default(now())

  @@unique([nodeId, forecastDate])
  @@index([forecastDate])
}

model Client {
  id           String          @id @default(cuid())
  name         String
  slug         String          @unique
  contactEmail String?
  status       String          @default("active")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  sites        Site[]
  credentials  ApiCredential[]

  @@index([status])
}

model Site {
  id           String          @id @default(cuid())
  clientId     String
  client       Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name         String
  code         String          @unique
  location     String
  timezone     String          @default("UTC")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  nodes        EdgeNode[]
  credentials  ApiCredential[]

  @@index([clientId])
}

model ApiCredential {
  id        String      @id @default(cuid())
  provider  ApiProvider
  name      String
  keyLast4  String
  isActive  Boolean     @default(true)
  notes     String?
  clientId  String?
  siteId    String?
  client    Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  site      Site?       @relation(fields: [siteId], references: [id], onDelete: SetNull)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([provider])
  @@index([clientId])
  @@index([siteId])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String?
  message    String?
  metadata   Json?
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId, createdAt])
  @@index([createdAt])
}
